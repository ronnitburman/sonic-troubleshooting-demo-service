SPATH       := $($(SONIC_TROUBLESHOOTING_DEMO_SERVICE)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) \
               rules/sonic-troubleshooting-demo-service.mk \
               rules/sonic-troubleshooting-demo-service.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)

SMDEP_FILES := $(addprefix $(SPATH)/,$(shell cd $(SPATH) && git ls-files))

$(SONIC_TROUBLESHOOTING_DEMO_SERVICE)_CACHE_MODE  := GIT_CONTENT_SHA
$(SONIC_TROUBLESHOOTING_DEMO_SERVICE)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(SONIC_TROUBLESHOOTING_DEMO_SERVICE)_DEP_FILES   := $(DEP_FILES)
$(SONIC_TROUBLESHOOTING_DEMO_SERVICE)_SMDEP_FILES := $(SMDEP_FILES)
$(SONIC_TROUBLESHOOTING_DEMO_SERVICE)_SMDEP_PATHS := $(SPATH)

$(SONIC_TROUBLESHOOTING_DEMO_SERVICE_DEB)_CACHE_MODE  := GIT_CONTENT_SHA
$(SONIC_TROUBLESHOOTING_DEMO_SERVICE_DEB)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(SONIC_TROUBLESHOOTING_DEMO_SERVICE_DEB)_DEP_FILES   := $(DEP_FILES)
$(SONIC_TROUBLESHOOTING_DEMO_SERVICE_DEB)_SMDEP_FILES := $(SMDEP_FILES)
$(SONIC_TROUBLESHOOTING_DEMO_SERVICE_DEB)_SMDEP_PATHS := $(SPATH)
